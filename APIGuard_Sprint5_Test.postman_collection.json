{
	"info": {
		"_postman_id": "b1a2c3d4-e5f6-4a5b-9c8d-7e6f5a4b3c2d",
		"name": "API Guard - Sprint 5 (Multi-Tenancy)",
		"description": "Collection to test the Multi-Tenant refactor (Custom Tiers) implemented in Sprint 5.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Auth",
			"item": [
				{
					"name": "Register Owner",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"owner@example.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set(\"token\", jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"owner@example.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "2. API Management",
			"item": [
				{
					"name": "Register API",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.id) {",
									"    pm.collectionVariables.set(\"apiId\", jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Weather API\",\n    \"targetUrl\": \"http://weather-service:8080\",\n    \"proxyPath\": \"weather-{{$randomInt}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/apis",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"apis"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "3. Custom Tiers (Sprint 5)",
			"item": [
				{
					"name": "Create Plan (Gold)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.id) {",
									"    pm.collectionVariables.set(\"planId\", jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Gold\",\n    \"rateLimitRpm\": 500,\n    \"monthlyQuota\": 100000,\n    \"webhookEnabled\": true\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/apis/{{apiId}}/plans",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"apis",
								"{{apiId}}",
								"plans"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Plans for API",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/apis/{{apiId}}/plans",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"apis",
								"{{apiId}}",
								"plans"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "4. API Keys",
			"item": [
				{
					"name": "Generate Key for Custom Tier",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/keys/generate?apiId={{apiId}}&planId={{planId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"keys",
								"generate"
							],
							"query": [
								{
									"key": "apiId",
									"value": "{{apiId}}"
								},
								{
									"key": "planId",
									"value": "{{planId}}"
								}
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8081",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "apiId",
			"value": "",
			"type": "string"
		},
		{
			"key": "planId",
			"value": "",
			"type": "string"
		}
	]
}
